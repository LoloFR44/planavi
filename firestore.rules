rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Plannings ──────────────────────────────────────
    // Read: anyone (public pages need this)
    // Create: authenticated users only (must set adminUid to their own UID)
    // Update/Delete: only the planning owner (adminUid must match)
    match /plannings/{planningId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.adminUid == request.auth.uid
        && request.resource.data.keys().hasAll(['residentName', 'slug', 'adminUid']);

      allow update: if request.auth != null
        && resource.data.adminUid == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.adminUid == request.auth.uid;
    }

    // ── Time Slots ─────────────────────────────────────
    // Read: anyone (public calendar)
    // Write: authenticated users only
    match /timeSlots/{slotId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['planningId', 'date', 'startTime', 'endTime']);

      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Bookings ───────────────────────────────────────
    // Read: anyone (public page shows visitor names)
    // Create: anyone (visitors book without account)
    // Delete: authenticated only (admin cancels bookings)
    // Update: blocked
    match /bookings/{bookingId} {
      allow read: if true;

      allow create: if request.resource.data.keys()
        .hasAll(['planningId', 'timeSlotId', 'visitorFirstName', 'visitorLastName', 'visitorCount']);

      allow delete: if request.auth != null;
      allow update: if false;
    }

    // ── Messages ───────────────────────────────────────
    // Create: anyone (visitors can leave messages)
    // Read: anyone
    // Delete: authenticated only (admin moderation)
    // Update: blocked
    match /messages/{messageId} {
      allow read: if true;

      allow create: if request.resource.data.keys()
        .hasAll(['planningId', 'content', 'createdAt']);

      allow delete: if request.auth != null;
      allow update: if false;
    }

    // ── Deny everything else ───────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
